# Copy to `.env` in the project root (same folder as `pyproject.toml`).
# The bridge loads this automatically on startup.

# Required: OpenAI API key for the Realtime / Agents SDK
OPENAI_API_KEY=sk-...

# Server
PORT=8000

# Optional: MeetStream bridge tuning (see README)
# MEETSTREAM_BOT_NAME=My Assistant
# MEETSTREAM_IGNORE_SPEAKERS=Some Bot Name,Another Name
# AGENT_SPEAKER_KEYWORDS=bot,agent,assistant,ai
# MEETSTREAM_IN_RATE=48000
# MEETSTREAM_OUT_RATE=48000
# MODEL_AUDIO_RATE=24000
# Batch model TTS into larger sendaudio chunks (ms at model rate, 40–2000; default 240)
# MEETSTREAM_OUT_AUDIO_CHUNK_MS=240
# MEETSTREAM_SENDAUDIO_PACE_MS=0

# Optional MCP — default Canva is in mcp.config.json (needs Node/npx). See docs/mcp.md.
# MCP_CONFIG=/path/to/mcp.config.json
# FRAMER_MCP_SSE_URL=
# N8N_MCP_REMOTE_URL=

# Optional: Docker / remote MCP over HTTP streamable (e.g. ngrok → Docker). Merged with mcp.config.json.
# DOCKER_MCP_ENABLED=0
# DOCKER_MCP_URL=https://your-subdomain.ngrok-free.app/mcp
# DOCKER_MCP_BEARER_TOKEN=raw-secret-only
# (Do not include the word "Bearer"; the app adds "Authorization: Bearer <token>".)
# DOCKER_MCP_SESSION_TIMEOUT=120
